{
  "name": "fire-sky-now",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:sync": "npx cap sync",
    "mobile:copy": "npx cap copy",
    "mobile:add:android": "npx cap add android",
    "mobile:add:ios": "npx cap add ios",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:doctor": "npx cap doctor",
    "mobile:android:bundle": "cd android && gradlew.bat bundleRelease",
    "mobile:android:assemble": "cd android && gradlew.bat assembleRelease",
    "mobile:ios:pods": "cd ios/App && pod install",
    "mobile:preflight": "npm run mobile:build && npm run mobile:doctor",
    "mobile:wrangler:dev": "wrangler pages dev dist --port 8788 --ip 0.0.0.0",
    "mobile:build:local": "cross-env VITE_API_BASE_URL=http://10.0.2.2:8788 vite build && npx cap sync android",
    "mobile:android:install": "cd android && ./gradlew installDebug",
    "mobile:android:launch": "adb shell am start -n com.firesky.app/.MainActivity",
    "mobile:test:smoke": "bash scripts/android-smoke-test.sh"
  },
  "dependencies": {
    "@capacitor/android": "8.3.4",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/cli": "8.3.4",
    "@capacitor/core": "8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "8.3.4",
    "@capacitor/local-notifications": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@vitejs/plugin-react": "latest",
    "framer-motion": "latest",
    "leaflet": "^1.9.4",
    "lucide-react": "latest",
    "maplibre-gl": "^5.24.0",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "wrangler": "^4.0.0"
  }
}
